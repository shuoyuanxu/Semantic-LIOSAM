<launch>

    <arg name="project" default="lio_sam"/>
    <arg name="use_gps" default="true"/>
    <!-- semantic segmentation alongside LIO-SAM (needs PyTorch); off by default
         so the normal SLAM stack is unaffected. Enable with use_semantic:=true -->
    <arg name="use_semantic" default="false"/>

    <!-- Parameters -->
    <rosparam file="$(find lio_sam)/config/params.yaml" command="load" />

    <!--- LOAM -->
    <include file="$(find lio_sam)/launch/include/module_loam.launch" />

    <!--- Robot State TF -->
    <include file="$(find lio_sam)/launch/include/module_robot_state_publisher.launch" />

    <!--- Run Navsat (feeds the GPS factor) -->
    <include file="$(find lio_sam)/launch/include/module_navsat.launch" if="$(arg use_gps)"/>

    <!--- Semantic segmentation (publishes /semantic/labeled_cloud for RViz) -->
    <include file="$(find lio_sam)/launch/include/module_semantic.launch" if="$(arg use_semantic)"/>

    <!--- Run Rviz-->
    <include file="$(find lio_sam)/launch/include/module_rviz.launch" />

</launch>
