<launch>
    <!--
      Keyframe-rate semantic segmentation (RandLA-Net) + automatic semantic
      map generation, running alongside LIO-SAM (never in its critical path).

      ALL tuning knobs live in the `semantic:` section of config/params.yaml
      (topics, scan rate, robot-reflection radius, map voxel sizes, ground
      downsampling, noise removal, live-map refresh, ...). Private rosparams
      on the nodes still override the yaml if you need a one-off change.

      Classes: 0 trunk, 1 crown, 2 ground, 3 others.
      Outputs go to <savePCDDirectory>/semantic/ (default ~/Downloads/LOAM/),
      overwritten on every new run like the rest of the LIO-SAM output.
    -->

    <arg name="checkpoint" default="$(find lio_sam)/semantic/model/checkpoint.tar"/>

    <node pkg="lio_sam" type="segmentation_node.py" name="semantic_segmentation"
          output="screen" respawn="false">
        <param name="checkpoint" value="$(arg checkpoint)"/>
    </node>

    <!-- live clean map on /semantic/map + final map when the lidar goes quiet -->
    <node pkg="lio_sam" type="semantic_map_finisher.py" name="semantic_map_finisher"
          output="screen" respawn="false"/>

</launch>
